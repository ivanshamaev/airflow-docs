.woff2) format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic-ext */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD2OwGtT0rU3BE.woff2) format('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* cyrillic */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD_OwGtT0rU3BE.woff2) format('woff2');\n  unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;\n}\n/* greek */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD4OwGtT0rU3BE.woff2) format('woff2');\n  unicode-range: U+0370-0377, U+037A-037F, U+0384-038A, U+038C, U+038E-03A1, U+03A3-03FF;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD0OwGtT0rU3BE.woff2) format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD1OwGtT0rU3BE.woff2) format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 100 800;\n  font-display: swap;\n  src: url(https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbV2o-flEEny0FZhsfKu5WU4xD7OwGtT0rU.woff2) format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n\n:root {\n  /* Red Color Scale */\n  --red-05: #fff2f3;\n  --red-10: #ffe3e5;\n  --red-20: #ffb6bb;\n  --red-30: #ff929a;\n  --red-40: #fd6d77;\n  --red-50: #f03a47;\n  --red-60: #c5283d;\n  --red-70: #b4162b;\n  --red-80: #9a0b1e;\n  --red-90: #7b0011;\n  --red-pink: #ed749d;\n\n  /* Gold Color Scale */\n  --gold-05: #fffaf1;\n  --gold-10: #fff1d8;\n  --gold-20: #ffe3b3;\n  --gold-30: #ffd07d;\n  --gold-40: #ffb32d;\n  --gold-50: #e89428;\n  --gold-60: #dd8513;\n  --gold-70: #c2730c;\n  --gold-80: #a55d05;\n  --gold-90: #7f4002;\n\n  /* Teal Color Scale */\n  --teal-05: #e3fbff;\n  --teal-10: #c2f7ff;\n  --teal-20: #95e8f5;\n  --teal-30: #74d5e4;\n  --teal-40: #44c9de;\n  --teal-50: #13bdd7;\n  --teal-60: #00a2bb;\n  --teal-70: #0095ac;\n  --teal-80: #008397;\n  --teal-90: #006271;\n\n  /* Green Color Scale */\n  --green-05: #e6fff0;\n  --green-10: #c4f9da;\n  --green-20: #95f1ba;\n  --green-30: #6bde99;\n  --green-40: #42cc7a;\n  --green-50: #19ba5a;\n  --green-60: #118a06;\n  --green-70: #0d7503;\n  --green-80: #0a5702;\n  --green-90: #053900;\n\n  /* Blue Color Scale */\n  --blue-05: #f0f5ff;\n  --blue-10: #d2e3ff;\n  --blue-20: #adcbff;\n  --blue-30: #81afff;\n  --blue-40: #5493ff;\n  --blue-50: #2676ff;\n  --blue-60: #0458ea;\n  --blue-70: #024bc9;\n  --blue-80: #003da6;\n  --blue-90: #00276a;\n\n  /* Purple Color Scale */\n  --purple-05: #f7f3ff;\n  --purple-10: #e8dbfe;\n  --purple-20: #d9c2fe;\n  --purple-30: #c9aafd;\n  --purple-40: #ba91fc;\n  --purple-50: #a067fb;\n  --purple-60: #872ded;\n  --purple-70: #6d23c0;\n  --purple-80: #521993;\n  --purple-90: #380e65;\n  --purple-95: #1d0438;\n  --purple-99: #0d011a;\n\n  /* New Moon Color Scale */\n  --new-moon-05: #f8f5f2;\n  --new-moon-10: #f0ece5;\n  --new-moon-20: #e9e2d8;\n  --new-moon-30: #d0c9c2;\n  --new-moon-40: #b6b1ad;\n  --new-moon-50: #969194;\n  --new-moon-60: #75727a;\n  --new-moon-70: #555261;\n  --new-moon-80: #343247;\n  --new-moon-90: #1d1d2c;\n  --new-moon-95: #111121;\n  --new-moon-99: #040416;\n\n  /* Grey Color Scale */\n  --grey-05: #f7fafc;\n  --grey-10: #edf2f7;\n  --grey-20: #e2e8f0;\n  --grey-30: #cbd5e0;\n  --grey-40: #a0aec0;\n  --grey-50: #718096;\n  --grey-60: #4a5568;\n  --grey-70: #272f41;\n  --grey-80: #1a202c;\n  --grey-90: #171923;\n  --grey-95: #111219;\n  --grey-99: #0c0d11;\n\n  /* Legacy color mappings for backwards compatibility */\n  --ruby-50: var(--red-05);\n  --ruby-100: var(--red-10);\n  --ruby-200: var(--red-20);\n  --ruby-300: var(--red-30);\n  --ruby-400: var(--red-40);\n  --ruby-500: var(--red-50);\n  --ruby-600: var(--red-60);\n  --ruby-700: var(--red-70);\n  --ruby-800: var(--red-80);\n\n  --topaz-50: #ffeee1;\n  --topaz-100: #ffd9bd;\n  --topaz-200: #ffc399;\n  --topaz-300: #ff9d61;\n  --topaz-400: #ff792e;\n  --topaz-500: #d85d15;\n  --topaz-600: #b14807;\n  --topaz-700: #8a3700;\n  --topaz-800: #632800;\n\n  --amber-50: var(--gold-05);\n  --amber-100: var(--gold-10);\n  --amber-200: var(--gold-20);\n  --amber-300: var(--gold-30);\n  --amber-400: var(--gold-40);\n  --amber-500: var(--gold-50);\n  --amber-600: var(--gold-60);\n  --amber-700: var(--gold-70);\n  --amber-800: var(--gold-80);\n\n  --emerald-50: var(--green-05);\n  --emerald-100: var(--green-10);\n  --emerald-200: var(--green-20);\n  --emerald-300: var(--green-30);\n  --emerald-400: var(--green-40);\n  --emerald-500: var(--green-50);\n  --emerald-600: var(--green-60);\n  --emerald-700: var(--green-70);\n  --emerald-800: var(--green-80);\n\n  --sapphire-50: var(--blue-05);\n  --sapphire-100: var(--blue-10);\n  --sapphire-200: var(--blue-20);\n  --sapphire-300: var(--blue-30);\n  --sapphire-400: var(--blue-40);\n  --sapphire-500: var(--blue-50);\n  --sapphire-600: var(--blue-60);\n  --sapphire-700: var(--blue-70);\n  --sapphire-800: var(--blue-80);\n\n  --amethyst-50: var(--purple-05);\n  --amethyst-100: var(--purple-10);\n  --amethyst-200: var(--purple-20);\n  --amethyst-300: var(--purple-30);\n  --amethyst-400: var(--purple-40);\n  --amethyst-500: var(--purple-50);\n  --amethyst-600: var(--purple-60);\n  --amethyst-700: var(--purple-70);\n  --amethyst-800: var(--purple-80);\n\n  --moonshot-25: var(--new-moon-05);\n  --moonshot-50: var(--new-moon-10);\n  --moonshot-75: var(--new-moon-20);\n  --moonshot-100: var(--new-moon-30);\n  --moonshot-150: var(--new-moon-30);\n  --moonshot-200: var(--new-moon-50);\n  --moonshot-300: var(--new-moon-50);\n  --moonshot-400: var(--new-moon-60);\n  --moonshot-500: var(--new-moon-70);\n  --moonshot-600: var(--new-moon-80);\n  --moonshot-700: var(--new-moon-90);\n  --moonshot-800: var(--new-moon-95);\n  --moonshot-900: var(--new-moon-99);\n  --moonshot-950: var(--new-moon-99);\n\n  /* Main colors */\n  --white: #ffffff;\n  --black: var(--new-moon-99);\n\n  /* Surface colors */\n  --surface-secondary: var(--grey-10);\n\n  /* Typography */\n  --theme-font-family-heading: \"League Gothic\", sans-serif;\n  --theme-font-family-body: \"Roboto\", \"Inter\", sans-serif;\n  --theme-font-family-mono: \"Roboto Mono\", monospace;\n\n  /* Theme colors */\n  --theme-primary-color: var(--new-moon-90);\n  --theme-background-color: var(--white);\n  --theme-accent-color: var(--gold-40);\n  --theme-secondary-color: var(--new-moon-70);\n}\n\n/**\nFern doesn't make it easy to add classes to their existing templates, at least on our current subscription.\nSo you'll notice we set our brand standard classes for h1, h2 etc but the fern classes will have different sizes.\n\nSorry for any confusion! This is intentional though so the acds classes stay consistent but we target the fern\nelements to be styled properly.\n\n- Katie\n**/\n\n.acds-h1,\n.acds-h2,\n.acds-h3,\n.acds-h4,\n.acds-h5,\n.fern-page-heading,\n.fern-prose h2 {\n  font-family: var(--theme-font-family-heading, \"Albert Sans\");\n  font-weight: 700;\n  text-wrap: pretty;\n}\n\n.acds-h1 {\n  font-size: 60px;\n  line-height: 1.13;\n}\n\n.acds-h2 {\n  font-size: 50px;\n  line-height: 1.24;\n}\n\n.acds-h3 {\n  font-size: 40px;\n  line-height: 1.2;\n}\n\n.acds-h4,\n.fern-page-heading {\n  font-size: 32px;\n  line-height: 1.25;\n}\n\n.acds-h5,\n.fern-prose h2 {\n  font-size: 24px;\n  line-height: 1.4;\n}\n\n.fern-prose h3 {\n  font-size: 1.2rem;\n}\n\n.acds-body-md {\n  font-family: var(--theme-font-family-body, \"Inter\");\n  font-size: 18px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 1.66;\n}\n\n.acds-body-xl {\n  font-size: 26px;\n  line-height: 1.54;\n}\n\n.acds-body-lg {\n  font-size: 22px;\n  line-height: 1.54;\n}\n\n.acds-body-sm {\n  font-size: 16px;\n  line-height: 1.5;\n}\n\n.acds-body-xs {\n  font-size: 14px;\n  line-height: 1.5;\n}\n\n.acds-eyebrow--hero,\n.acds-eyebrow,\n.fern-breadcrumb-item {\n  color: var(--amethyst-400, #af76ff);\n  font-family: \"JetBrains Mono\";\n  font-size: 11px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: 1.64;\n  letter-spacing: 1.1px;\n  text-transform: uppercase;\n}\n\n.fern-prose p {\n  font-family: \"Inter\";\n}\n\n.toc-root a {\n  font-family: \"Inter\";\n  font-weight: 500 !important;\n  line-height: 2.08 !important;\n}\n\n.toc-root a[class~=\"text-(color:--accent-a11)\"] {\n  font-weight: 500 !important;\n  line-height: 2.08 !important;\n}\n\n.code-block-root,\ncode,\npre {\n  font-family: var(--theme-font-family-mono, \"JetBrains Mono\");\n}\n\n.fern-prose p {\n  font-family: \"Inter\";\n  letter-spacing: 0.25px;\n  line-height: 1.5;\n  text-wrap: pretty;\n}\n\n.fern-prose ul,\n.fern-prose ol {\n  margin-block: 1.5rem;\n}\n\n* {\n  scroll-behavior: smooth;\n}\n\n.acds-link {\n  color: var(--amethyst-400);\n}\n\n.acds-link.sm {\n  font-size: 1rem;\n}\n\n.acds-container {\n  container-name: acds-container;\n  container-type: inline-size;\n  max-width: 1440px;\n  margin: auto;\n}\n\n.promoBanner .highlight {\n  color: var(--amethyst-400);\n  margin-left: 0.25rem;\n}\n\n.acds-row-flow \u003e * + * {\n  margin-top: var(--row-flow-margin, 22px);\n}\n\n.acds-has-bg-line::before,\n.acds-has-bg-line::after {\n  content: \"\";\n  height: 2px;\n  background: rgba(175, 118, 255, 0.3);\n  width: 1000%;\n  display: block;\n  position: absolute;\n  top: 50%;\n  left: -1000%;\n  z-index: 0;\n}\n\n.acds-has-bg-line::after {\n  left: unset;\n  right: -1000%;\n}\n\n.acds-breadcrumbs {\n  --container-width: 1000px;\n  padding: 0 1rem;\n  gap: 0.25rem;\n  margin-top: -5rem;\n  margin-bottom: 4rem;\n  position: relative;\n  z-index: 2;\n}\n\n.acds-breadcrumbs li:not(:last-child)::after {\n  content: \"›\";\n  display: inline;\n  margin: 0 0.25rem;\n  font-size: 1rem;\n  line-height: 1.125;\n}\n\n.header:not(.menuIsOpen) a.acds-button.outline,\n.header:not(.fill-bg) a.acds-button.outline {\n  color: var(--moonshot-700) !important;\n}\n\n.header.menuIsOpen a.acds-button.outline {\n  color: white !important;\n}\n\n.header[data-theme=\"dark\"] a.acds-button.outline {\n  color: white !important;\n}\n\n.acds-footer .acds-form input {\n  border-radius: 50px;\n  padding-left: 70px;\n}\n\n.acds-tag {\n  padding: 5px 10px;\n  text-align: center;\n  border-radius: 5px;\n  background: var(--amethyst-100, #ede1ff);\n  color: var(--moonshot-700, #2b215b);\n  font-family: \"JetBrains Mono\";\n  font-size: 10px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: 1.8;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n}\n\n.acds-loader {\n  border: 8px solid var(--moonshot-50);\n  border-top: 8px solid var(--amethyst-400);\n  border-radius: 50%;\n  width: 50px;\n  height: 50px;\n  animation: acds-loader-spin 1s linear infinite;\n}\n\n@keyframes acds-loader-spin {\n  0% {\n    transform: rotate(0deg);\n  }\n  100% {\n    transform: rotate(360deg);\n  }\n}\n\n.fern-sidebar-link[data-state=\"active\"] {\n  border-radius: 5px;\n  background: var(--moonshot-25, #f8f8ff);\n}\n\nhtml.dark .fern-sidebar-link[data-state=\"active\"] {\n  background: var(--moonshot-600, #413a77) !important;\n  color: var(--moonshot-150, #bdbfe2) !important;\n}\n\n.fern-callout {\n  border-radius: 10px;\n  padding: 16px 26px;\n  line-height: 1.5;\n}\n\n.fern-callout a {\n  color: inherit;\n  font-weight: 400;\n  line-height: 18px;\n  text-decoration-line: underline;\n  text-decoration-style: solid;\n  text-decoration-skip-ink: auto;\n  text-decoration-thickness: auto;\n  text-underline-offset: auto;\n  text-underline-position: from-font;\n}\n\nhtml.dark .fern-callout[data-intent=\"tip\"] {\n  border: 1px solid var(--Emerald-800, #08483a);\n  background: rgba(11, 205, 147, 0.2);\n  color: var(--emerald-100, #c6f7e1);\n}\n\nhtml.dark .fern-callout[data-intent=\"info\"] {\n  border: 1px solid var(--moonshot-600, #413a77);\n  background: var(--moonshot-700, #2b215b);\n  color: var(--moonshot-50, #ebe9f8);\n}\n\n.fern-callout[data-intent=\"tip\"] {\n  border: 1px solid var(--emerald-400, #0bcd93);\n  background: var(--emerald-50, #f2fff8);\n  color: var(--emerald-600, #068a6a);\n}\n\n.fern-callout[data-intent=\"info\"] {\n  border: 1px solid var(--amethyst-400, #af76ff);\n  background: var(--moonshot-25, #f8f8ff);\n  color: var(--moonshot-600, #413a77);\n}\n\ndiv.fern-layout-guide {\n  margin-left: 0;\n  padding-right: 1rem !important;\n}\n\n@media screen and (min-width: 980px) {\n  #fern-toc + .max-w-full,\n  #fern-toc + .fern-layout-guide .max-w-full {\n    max-width: 100%;\n    width: 800px;\n  }\n}\n\n.flex-container {\n  display: flex;\n  align-items: center;\n  justify-content: start;\n  flex-wrap: wrap;\n  gap: var(--flex-container-gap, 1.5rem);\n  flex-direction: var(--flex-container-direction, row);\n}\n\nheader a[href=\"https://www.astronomer.io/docs/\"] {\n  border-bottom: 2px solid var(--amethyst-300);\n}\n\n[data-theme=\"default\"]#fern-header .fern-header-content {\n  height: max-content;\n}\n\n.fern-callout .fern-button-group {\n  margin-bottom: 0;\n}\n\n.dark {\n  --accent: var(--gold-40);\n  --background: var(--new-moon-90);\n}\n\nhtml.dark #fern-header {\n  background: var(--new-moon-90);\n}\n\nhtml.dark .acds-button.filled.normal {\n  color: black !important;\n}\n\nhtml.light #fern-header {\n  background: var(--white);\n}\n\nhtml.light .dropdownTitle:hover {\n  color: var(--new-moon-10) !important;\n}\n\n.acds-button,\n.acds-button:visited,\nbutton.mktoButton.mktoButton {\n  /* CSS Custom Properties - Override these for page-specific button styles */\n  --button-background-color: var(--gold-40, #ffb32d);\n  --button-color: var(--new-moon-90, #1d1d2c);\n  --button-background-color-hover: var(--new-moon-20);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n\n  display: flex;\n  text-decoration: none !important;\n  text-align: center;\n  border-radius: 5px !important;\n  background: var(--button-background-color);\n  padding: 11.41px 23.96px !important;\n  color: var(--button-color);\n  transition: all 0.3s ease;\n  cursor: pointer;\n  min-width: max-content;\n  font-style: normal;\n  font-weight: 600 !important;\n  font-size: 14px;\n  line-height: 2.14;\n  letter-spacing: 0.2738px;\n  border: 3px solid var(--button-border-color);\n  font-family: var(--theme-font-family-body);\n}\n\nbutton.mktoButton.mktoButton {\n  border-radius: 0;\n}\n\n/* Hover States */\n.acds-button:hover,\n.acds-button:focus {\n  background: var(--button-background-color-hover, --new-moon-20);\n  color: var(--button-color-hover, var(--button-color));\n  text-decoration: none;\n}\n\n/* Secondary Button (Grey) */\n.acds-button.secondary {\n  --button-background-color: var(--new-moon-80);\n  --button-color: var(--white, #ffffff);\n  --button-background-color-hover: var(--new-moon-90);\n  --button-color-hover: var(--white, #ffffff);\n}\n\n/* Outline Button */\n.acds-button.outline {\n  --button-background-color: transparent;\n  --button-background-color-hover: var(--new-moon-20);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n\n  background: var(--button-background-color);\n  color: var(--button-color);\n  border: 3px solid var(--button-border-color);\n}\n\n.acds-button.outline:hover,\n.acds-button.outline:focus {\n  filter: none;\n  color: var(--button-color-hover);\n  background: var(--button-background-color-hover);\n  border-color: var(--button-background-color-hover);\n}\n\n/* Purple Outline Button - For Header/Nav */\n.acds-button.outline.purple {\n  --button-background-color: transparent;\n  --button-color: var(--purple-40, #ba91fc);\n  --button-border-color: var(--purple-40, #ba91fc);\n  --button-background-color-hover: var(--purple-40, #ba91fc);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n  --button-border-color-hover: var(--purple-40, #ba91fc);\n}\n\n/* Ghost Button */\n.acds-button.ghost {\n  --button-background-color: transparent;\n  --button-color: var(--gold-40, #ffb32d);\n  --button-border-color: transparent;\n  --button-background-color-hover: rgba(255, 179, 45, 0.1);\n  --button-color-hover: var(--gold-40, #ffb32d);\n  --button-border-color-hover: transparent;\n\n  background: var(--button-background-color);\n  color: var(--button-color);\n  border: 3px solid var(--button-border-color);\n  font-family: var(--theme-font-family-mono);\n  font-size: 14px;\n  font-weight: 600;\n  line-height: 18px;\n  letter-spacing: 1.4px;\n  text-transform: uppercase;\n  padding: 0;\n}\n\n.acds-button.ghost::after {\n  content: \"→\";\n  margin-left: 0.5rem;\n  width: 24px;\n  height: 24px;\n  transition: transform 0.3s ease;\n  margin-top: 8px;\n  line-height: 1.28;\n}\n\n.acds-button.ghost:hover,\n.acds-button.ghost:focus {\n  filter: none;\n  transform: translateY(0);\n  box-shadow: none;\n}\n\n.acds-button.ghost:hover::after {\n  transform: translate(6px, 0px);\n}\n\n/* Size Variants */\n.acds-button.lg,\n.acds-button.large {\n  font-size: 16px;\n  line-height: 40px;\n  letter-spacing: 0.32px;\n  padding: 13px 26px;\n}\n\n.acds-button.md,\n.acds-button.medium {\n  font-size: 13.692px;\n  line-height: 34.23px;\n  letter-spacing: 0.2738px;\n  padding: 11.41px 23.96px;\n}\n\n.acds-button.sm,\n.acds-button.small {\n  font-size: 12px;\n  line-height: 30px;\n  letter-spacing: 0.24px;\n  padding: 10px 20px;\n}\n\n.acds-button.xs,\n.acds-button.xsmall {\n  font-size: 11px;\n  line-height: 27.5px;\n  letter-spacing: 0.22px;\n  padding: 8px 16px;\n}\n\n/* Text Color Overrides */\n.acds-button.dark-text {\n  --button-color: var(--new-moon-90, #1d1d2c);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n}\n\n.acds-button.text-white {\n  --button-color: var(--white, #ffffff);\n  --button-color-hover: var(--white, #ffffff);\n}\n\n.acds-button.text-gold {\n  --button-color: var(--gold-40, #ffb32d);\n  --button-color-hover: var(--gold-40, #ffb32d);\n}\n\n/* Purple/Amethyst Variant (Legacy Support) */\n.acds-button.purple,\n.acds-button.amethyst {\n  --button-background-color: var(--purple-60, #872ded);\n  --button-color: var(--white, #ffffff);\n  --button-border-color: var(--purple-60, #872ded);\n  --button-background-color-hover: var(--purple-70, #6b24be);\n  --button-color-hover: var(--white, #ffffff);\n  --button-border-color-hover: var(--purple-70, #6b24be);\n}\n\n/* Gold Variant */\n.acds-button.gold {\n  --button-background-color: var(--gold-40, #ffb32d);\n  --button-color: var(--new-moon-90, #1d1d2c);\n  --button-background-color-hover: var(--new-moon-20, #f5a623);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n}\n\n/* Gold Outline Button */\n.acds-button.outline.gold {\n  --button-background-color: transparent;\n  --button-color: var(--gold-40, #ffb32d);\n  --button-border-color: var(--gold-40, #ffb32d);\n  --button-background-color-hover: var(--new-moon-20, #ffb32d);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n  --button-border-color-hover: var(--gold-40, #ffb32d);\n}\n\n/* Teal Variant */\n.acds-button.teal {\n  --button-background-color: var(--teal-40, #13bdd7);\n  --button-color: var(--new-moon-90, #1d1d2c);\n  --button-border-color: var(--teal-40, #13bdd7);\n  --button-background-color-hover: var(--teal-50, #0ea5bd);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n  --button-border-color-hover: var(--teal-50, #0ea5bd);\n}\n\n/* Teal Outline Button */\n.acds-button.outline.teal {\n  --button-background-color: transparent;\n  --button-color: var(--teal-40, #13bdd7);\n  --button-border-color: var(--teal-40, #13bdd7);\n  --button-background-color-hover: var(--teal-40, #13bdd7);\n  --button-color-hover: var(--new-moon-90, #1d1d2c);\n  --button-border-color-hover: var(--teal-40, #13bdd7);\n}\n\n/* Disabled State */\n.acds-button:disabled,\n.acds-button.disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n  pointer-events: none;\n}\n\n/* Full Width */\n.acds-button.full-width {\n  width: 100%;\n  display: block;\n}\n\n/* Button with Icon */\n.acds-button .icon {\n  display: inline-block;\n  margin-right: 8px;\n  vertical-align: middle;\n}\n\n.acds-button .icon:last-child {\n  margin-right: 0;\n  margin-left: 8px;\n}\n\n/* Responsive Adjustments */\n@media screen and (max-width: 768px) {\n  .acds-button {\n    padding: 10px 20px;\n    font-size: 12px;\n    line-height: 30px;\n    letter-spacing: 0.24px;\n  }\n\n  .acds-button.lg,\n  .acds-button.large {\n    font-size: 13.692px;\n    line-height: 34.23px;\n    letter-spacing: 0.2738px;\n    padding: 11.41px 23.96px;\n  }\n\n  .acds-button.sm,\n  .acds-button.small {\n    font-size: 11px;\n    line-height: 27.5px;\n    letter-spacing: 0.22px;\n    padding: 8px 16px;\n  }\n\n  .acds-button.sm.ghost {\n    font-size: 12px;\n    line-height: 30px;\n  }\n}\n\n@media screen and (max-width: 320px) {\n  .acds-button.sm.ghost {\n    font-size: 10px;\n  }\n}\n\n/* Focus Visible for Accessibility */\n.acds-button:focus-visible {\n  outline: 3px solid var(--purple-40, #ba91fc);\n  outline-offset: 2px;\n}\n\n.fern-announcement .fern-mdx-link {\n  color: white;\n  text-decoration: underline;\n  text-decoration-thickness: 1px;\n}\n.fern-product-selector-radio-group {\n  display: grid;\n  gap: 12px 8px;\n}\n\n@media screen and (min-width: 700px) {\n  .fern-product-selector-radio-group {\n    grid-template-columns: repeat(2, 300px);\n  }\n}\n#fern-header {\n  border: none;\n}\n\n.header[data-theme=\"dark\"] .acds-button.outline {\n  border: 2px solid var(--moonshot-300);\n}\n\n.headerNav a.acds-button.outline {\n  padding: 4px 20px !important;\n}\n\n#fern-header\n  \u003e div\n  \u003e div.fern-header-content\n  \u003e div\n  \u003e div\n  \u003e div.fern-header-logo-container\n  \u003e div\n  \u003e div.flex.items-center.lg\\:items-start {\n  order: -1;\n}\n\n.fern-header-content {\n  padding-block: 1rem;\n}\n.fern-header-logo-container .flex.items-center.gap-2 {\n  gap: 2rem;\n}\n\n/* Hide subtitle and icon in product switcher button */\nbutton .fern-selection-item-subtitle,\nbutton .fern-selection-item-icon {\n  display: none;\n}\n\n/* Add spacing between product and version picker */\n.fern-version-selector {\n  margin-top: 8px;\n}\n\n.fern-layout-overview {\n  margin-inline: 0;\n}\n\n.acds-footer {\n  background: var(--new-moon-95, #111121);\n  padding: 2rem;\n  color: var(--new-moon-20, #e9e2d8);\n  z-index: 1;\n  position: relative;\n}\n\n.acds-footer__inner {\n  max-width: 1160px;\n  margin: auto;\n  display: grid;\n  gap: 60px;\n}\n\n.acds-footer__top {\n  display: grid;\n  gap: 80px;\n}\n\n.acds-footer__small-links .acds-footer__nav-item {\n  color: var(--new-moon-10, #f0ece5);\n  font-family: var(--theme-font-family-body);\n  font-size: 12px;\n  font-style: normal;\n  font-weight: 600;\n  line-height: 2.08;\n}\n\n@media screen and (min-width: 1280px) {\n  .acds-footer__top {\n    grid-template-columns: 1fr 158px;\n    justify-content: space-between;\n    align-items: flex-start;\n  }\n}\n\n.acds-footer__nav {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(112px, 1fr));\n  gap: 76px 70px;\n}\n\n.acds-footer .acds-eyebrow {\n  color: var(--new-moon-20, #e9e2d8);\n  font-family: var(--theme-font-family-mono);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: 20px;\n  letter-spacing: 1.1px;\n  text-transform: uppercase;\n}\n\n.acds-footer__nav-list {\n  display: grid;\n  gap: 12px;\n  margin-top: 12px;\n}\n\n.acds-footer__nav-item {\n  color: var(--new-moon-50, #969194);\n  font-family: var(--theme-font-family-body);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 1.66;\n  transition: color 0.3s ease;\n}\n\n.acds-footer__nav-item:hover,\n.acds-footer__nav-item:focus {\n  color: var(--gold-40, #ffb32d);\n}\n\n.acds-footer__small-text {\n  color: var(--new-moon-50, #969194);\n  font-family: var(--theme-font-family-body);\n  font-size: 12px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 2.27;\n}\n\n.acds-footer__small-text .acds-apache-link {\n  color: var(--new-moon-20, #e9e2d8);\n  text-decoration: underline;\n  transition: color 0.2s ease;\n}\n\n.acds-footer__small-text .acds-apache-link:hover,\n.acds-footer__small-text .acds-apache-link:focus {\n  color: var(--gold-40, #ffb32d);\n}\n\n.acds-footer__social {\n  display: flex;\n  gap: 26px;\n  align-items: center;\n}\n\n.acds-footer__social a {\n  transition: opacity 0.2s ease;\n}\n\n.acds-footer__social a:hover,\n.acds-footer__social a:focus {\n  opacity: 0.7;\n}\n\n.acds-footer__small-links {\n  display: flex;\n  align-items: center;\n}\n\n.acds-footer__bottom-links {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 28px;\n  flex-wrap: wrap;\n  gap: 80px;\n}\n\n@media screen and (min-width: 500px) {\n  .acds-footer {\n    padding: 112px 72px 112px 72px;\n  }\n}\n\n@media screen and (max-width: 900px) {\n  .acds-footer__nav {\n    display: grid;\n    grid-template-columns: repeat(2, minmax(112px, 1fr));\n    gap: 76px 70px;\n  }\n}\n\n@media screen and (max-width: 360px) {\n  .acds-footer__nav {\n    display: grid;\n    grid-template-columns: repeat(1, minmax(112px, 1fr));\n    gap: 76px 70px;\n  }\n}\n\n.fern-header header {\n  width: 100%;\n  background-color: transparent;\n  transition: background-color 0.4s;\n  z-index: 4;\n  padding-block-start: 0.5rem;\n  padding-block-end: 0.5rem;\n  border: none;\n}\n.headerWrapper {\n  --container-width: 1200px;\n  grid-template-columns: auto 1fr;\n  justify-content: space-between;\n  gap: 22px;\n  width: 100%;\n  padding-block-start: 1.25rem;\n  padding-block-end: 1.25rem;\n  padding-inline-start: 1rem;\n  padding-inline-end: 1rem;\n  display: grid;\n}\n.logo {\n  flex: 0 1 176px;\n  border-bottom: 4px solid transparent;\n  padding: 0.5rem 0;\n  position: relative;\n  z-index: 4;\n}\n.logo .logoTitle {\n  position: absolute;\n  left: -100%;\n  visibility: hidden;\n  opacity: 0;\n}\n.logo .logoImg {\n  display: block;\n  width: 176px;\n  height: 18px;\n  background-image: url(\"https://www.astronomer.io/logo.svg\");\n  background-size: contain;\n  background-position: center;\n  background-repeat: no-repeat;\n}\n@media screen and (max-width: 1278px) {\n  .logo .logoImg {\n    background-position: left;\n  }\n}\n.menuToggle {\n  display: none;\n  background: transparent;\n  border: none;\n  padding: 0;\n  cursor: pointer;\n  margin-top: 8px;\n  z-index: 4;\n}\n/** Animated Hamburger Icon */\n.hamburger {\n  display: inline-block;\n  transition-property: opacity, filter;\n  transition-duration: 0.15s;\n  transition-timing-function: linear;\n  overflow: visible;\n}\n.hamburger:hover,\n.hamburger.isActive:hover {\n  opacity: 0.7;\n}\n.hamburger.isActive .hamburgerInner,\n.hamburger.isActive .hamburgerInner::before,\n.hamburger.isActive .hamburgerInner::after {\n  background-color: var(--amethyst-500);\n}\n.hamburgerBox {\n  width: 22px;\n  height: 22px;\n  display: inline-block;\n  position: relative;\n}\n.hamburgerInner {\n  display: block;\n  top: 50%;\n  margin-top: -2px;\n}\n.hamburgerInner,\n.hamburgerInner::before,\n.hamburgerInner::after {\n  width: 22px;\n  height: 3px;\n  background-color: var(--amethyst-400);\n  position: absolute;\n  transition-property: transform;\n  transition-duration: 0.15s;\n  transition-timing-function: ease;\n}\n.hamburgerInner::before,\n.hamburgerInner::after {\n  content: \"\";\n  display: block;\n}\n.hamburgerInner::before {\n  top: -7px;\n}\n.hamburgerInner::after {\n  bottom: -7px;\n}\n.hamburgerCollapse .hamburgerInner {\n  top: auto;\n  bottom: 0;\n  transition-duration: 0.13s;\n  transition-delay: 0.13s;\n  transition-timing-function: cubic-bezier(0.55, 0.055, 0.675, 0.19);\n}\n.hamburgerCollapse .hamburgerInner::after {\n  top: -14px;\n  transition:\n    top 0.2s 0.2s cubic-bezier(0.33333, 0.66667, 0.66667, 1),\n    opacity 0.1s linear;\n}\n.hamburgerCollapse .hamburgerInner::before {\n  transition:\n    top 0.12s 0.2s cubic-bezier(0.33333, 0.66667, 0.66667, 1),\n    transform 0.13s cubic-bezier(0.55, 0.055, 0.675, 0.19);\n}\n.hamburgerCollapse.isActive .hamburgerInner {\n  transform: translate3d(0, -10px, 0) rotate(-45deg);\n  transition-delay: 0.22s;\n  transition-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);\n}\n.hamburgerCollapse.isActive .hamburgerInner::after {\n  top: 0;\n  opacity: 0;\n  transition:\n    top 0.2s cubic-bezier(0.33333, 0, 0.66667, 0.33333),\n    opacity 0.1s 0.22s linear;\n}\n.hamburgerCollapse.isActive .hamburgerInner::before {\n  top: 0;\n  transform: rotate(-90deg);\n  transition:\n    top 0.1s 0.16s cubic-bezier(0.33333, 0, 0.66667, 0.33333),\n    transform 0.13s 0.25s cubic-bezier(0.215, 0.61, 0.355, 1);\n}\n.fill-bg {\n  background-color: #16142f;\n}\n\nhtml.light .dropdownTitle {\n  color: var(--new-moon-90) !important;\n}\n\n@media screen and (max-width: 1278px) {\n  .headerWrapper {\n    gap: 0;\n  }\n  .menuToggle {\n    display: block;\n    width: 32px;\n  }\n\n  .headerWrapper {\n    grid-template-columns: 1fr auto;\n  }\n  .logo {\n    margin-top: 8px;\n  }\n  .isActive + .headerNav {\n    display: flex;\n  }\n\n  .menuToggle.isActive + .headerNav {\n    display: flex;\n  }\n}\n\n@media screen and (min-width: 1279px) {\n  html.light .menuToggle:not(.isActive) .hamburgerInner,\n  html.light .menuToggle:not(.isActive) .hamburgerInner::before,\n  html.light .menuToggle:not(.isActive) .hamburgerInner::after {\n    background-color: var(--moonshot-700) !important;\n  }\n}\n\nhtml.light:not(.menuIsOpen) .logoImg {\n  background-image: url(\"https://www.astronomer.io/logo/astronomer-dark.svg\") !important;\n}\n\n.header.fill-bg .logoImg {\n  background-image: url(\"https://www.astronomer.io/logo.svg\") !important;\n}\n\n@media screen and (max-width: 1278px) {\n  .header[data-theme=\"light\"].fill-bg .logoImg {\n    background-image: url(\"https://www.astronomer.io/logo.svg\") !important;\n  }\n\n  .headerNav .acds-button {\n    --button-color: white;\n  }\n}\n\n.headerNav .acds-button {\n  --button-background-color: var(--amethyst-500);\n}\n\n.headerNavList .buttons .acds-button.outline {\n  color: var(--moonshot-700) !important;\n}\n\n@media screen and (min-width: 1280px) {\n  html.light .header .dropdownTitle,\n  .light .dropdownTitle {\n    color: var(--moonshot-700) !important;\n  }\n\n  html.light .header .acds-button.outline,\n  .light .acds-button.outline {\n    --button-color: var(--moonshot-700);\n  }\n\n  html.light .header .dropdown-caret,\n  .light .dropdown-caret {\n    fill: var(--moonshot-700);\n  }\n}\n\n.header[data-theme=\"dark\"] .acds-button.outline,\n.dark .acds-button.outline {\n  --button-color: var(--white, #fff);\n}\n\n.label {\n  padding-inline: 10.54px;\n  flex: 0 1 max-content;\n  border-radius: 6.584px;\n  background: var(--amethyst-500, #af76ff);\n  color: var(--white, #fff);\n  font-family: \"JetBrains Mono\";\n  font-size: 9.218px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: 2.2;\n  letter-spacing: 0.922px;\n  display: inline-block;\n  height: 20px;\n}\n\n.copy {\n  flex: 1 1 auto;\n  justify-content: start;\n}\n\n.link {\n  color: white;\n  text-decoration: none;\n  font-family: \"Albert Sans\";\n  font-size: 16px;\n  font-weight: 600;\n  line-height: 28px;\n  display: flex;\n  align-items: center;\n  font-style: normal;\n  gap: 16px;\n}\n\n.link:hover {\n  filter: brightness(80%);\n}\n\n@media screen and (max-width: 689px) {\n  .promoBanner__utility-nav {\n    display: none;\n  }\n  .copy {\n    justify-content: center;\n  }\n}\n\n.product-dropdown-trigger,\n.version-dropdown-trigger {\n  font-size: 14px;\n  border: 1px solid #313752;\n}\n\n.light .product-dropdown-trigger,\n.light .version-dropdown-trigger {\n  border: 1px solid #e4dfe7;\n}\n\n.fern-header-logo-container .items-baseline {\n  gap: 0.75rem;\n}\n\n#acds-nav-buttons {\n  gap: 0.75rem;\n}\n\n.fern-header-navbar-links button {\n  order: -1;\n  margin-left: 0;\n  margin-right: 1rem;\n}\n\n.fern-header-content\n  .flex.w-full.items-center.justify-stretch.gap-4.max-w-page-width.mx-auto {\n  gap: 0.75rem;\n}\n\n/* Base Navigation Container */\n.headerNav {\n  position: relative;\n  display: flex;\n  gap: 2rem;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  font-family: var(--theme-font-family-body);\n  font-size: var(--font-size-nav);\n  line-height: var(--line-height-nav);\n  color: var(--white);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n}\n\n.headerNavList {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: var(--white);\n}\n\n/* Links \u0026 Dropdown Titles */\n.headerNav a,\n.dropdownTitle {\n  text-decoration: none;\n  color: var(--new-moon-10);\n}\n\n.headerNav a:focus,\n.dropdownTitle:focus {\n  outline: none;\n}\n\n.dropdownTitle {\n  background-color: transparent;\n  border: none;\n  cursor: pointer;\n  font-family: var(--theme-font-family-body);\n  font-size: 14px;\n  font-weight: 500;\n  line-height: 1.78;\n  color: var(--new-moon-10);\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  padding: 2px 12px;\n  transition: background-color 0.28s ease-out 0.12s;\n  anchor-name: --dropdown;\n  border-radius: 5px;\n}\n\n.dropdownTitle.isActive {\n  background: var(--new-moon-80);\n}\n\n/* Dropdown Container */\n.dropdown {\n  position: relative;\n}\n\n/* Dropdown Menu */\n.dropdownMenu {\n  position: absolute;\n  top: calc(anchor(top) + 36px);\n  padding: 8px;\n  width: max-content;\n  display: grid;\n  gap: 0;\n  visibility: hidden;\n  opacity: 0;\n  transition:\n    opacity 0.28s ease-out 0.12s,\n    visibility 0.28s ease-out 0.12s;\n  position-anchor: --dropdown;\n  /*filter: drop-shadow(0 0 15px rgba(29, 29, 44, 0.2));*/\n  border-radius: 5px;\n  background: rgba(29, 29, 44, 0.9);\n  box-shadow: 0 0 15px 2px rgba(29, 29, 44, 0.2);\n  /*backdrop-filter: blur(5.25px);*/\n}\n\n.dropdownMenu .child {\n  padding: 8px;\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n}\n\n.dropdownMenu .child.hasChildren {\n  gap: 10px;\n}\n\n/* Top Level Menu Links */\n.dropdownMenu .child \u003e a {\n  display: flex;\n  align-items: flex-start;\n  gap: 20px;\n  color: var(--white);\n  font-family: var(--theme-font-family-body);\n  font-size: 14px;\n  font-weight: 700;\n  line-height: 12px;\n  letter-spacing: 0.14px;\n  padding: 10px 20px;\n  border-radius: 5px;\n  transition: background-color 0.2s ease;\n  font-variation-settings: \"wdth\" 75;\n}\n\n.dropdownMenu .child \u003e a:hover {\n  background-color: rgba(255, 255, 255, 0.05);\n}\n\n.dropdownMenu .child \u003e a img {\n  width: 24px;\n  height: 24px;\n  flex-shrink: 0;\n  margin-top: 0;\n}\n\n/* Category Titles */\n.child.hasChildren .topTitle {\n  color: var(--new-moon-50);\n  font-family: var(--theme-font-family-mono);\n  font-size: 9px;\n  font-weight: 700;\n  line-height: 20px;\n  letter-spacing: 0.9px;\n  text-transform: uppercase;\n  margin-bottom: 0;\n  padding: 0;\n}\n\n/* Grandchildren (Nested Items) */\n.grandchildren {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.grandchildren.two-column {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 20px;\n  width: 100%;\n}\n\n.grandchild a.link {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.grandchild a.link .icon-wrapper {\n  position: relative;\n  display: inline-block;\n  width: 24px;\n  height: 24px;\n  flex-shrink: 0;\n  overflow: hidden;\n}\n\n.grandchild a.link img {\n  width: 24px;\n  height: 24px;\n  flex-shrink: 0;\n  position: absolute;\n  top: 0;\n  left: 0;\n  transition: opacity 0.3s ease;\n  object-fit: contain;\n}\n\n.grandchild--hasDescription:not(.isCTA) .link {\n  display: grid;\n  grid-template-columns: 24px 1fr;\n  gap: 20px;\n}\n\n.grandchild a.link img.icon-default {\n  opacity: 1;\n}\n\n.grandchild a.link img.icon-gold {\n  opacity: 0;\n}\n\n.grandchild:hover a.link img.icon-default,\n.grandchild a.link:hover img.icon-default,\n.grandchild:focus a.link img.icon-default,\n.grandchild a.link:focus img.icon-default {\n  opacity: 0;\n}\n\n.grandchild:hover a.link img.icon-gold,\n.grandchild a.link:hover img.icon-gold,\n.grandchild:focus a.link img.icon-gold,\n.grandchild a.link:focus img.icon-gold {\n  opacity: 1;\n}\n\n.grandchildren.two-column .grandchild {\n  padding: 0;\n}\n\n.grandchildren.two-column .grandchild a.link {\n  gap: 5px;\n  padding: 8px;\n}\n\n.grandchildren.two-column .grandchild a.link .icon-wrapper {\n  width: 12px;\n  height: 12px;\n  display: inline-block;\n  overflow: hidden;\n}\n\n.grandchildren.two-column .grandchild a.link img {\n  width: 12px;\n  height: 12px;\n  object-fit: contain;\n}\n\n.grandchildren.two-column .grandchild:hover a.link img.icon-default,\n.grandchildren.two-column .grandchild a.link:hover img.icon-default,\n.grandchildren.two-column .grandchild:focus a.link img.icon-default,\n.grandchildren.two-column .grandchild a.link:focus img.icon-default {\n  opacity: 0;\n}\n\n.grandchildren.two-column .grandchild:hover a.link img.icon-gold,\n.grandchildren.two-column .grandchild a.link:hover img.icon-gold,\n.grandchildren.two-column .grandchild:focus a.link img.icon-gold,\n.grandchildren.two-column .grandchild a.link:focus img.icon-gold {\n  opacity: 1;\n}\n\n/* Grandchild Text */\n.grandchild-text {\n  display: flex;\n  flex-direction: column;\n  gap: 5px;\n  flex: 1;\n}\n\n.grandchild-text .linkTitle {\n  font-family: var(--theme-font-family-body);\n  font-size: 12px;\n  font-weight: 600;\n  line-height: 12px;\n  letter-spacing: 0.12px;\n  font-variation-settings: \"wdth\" 100;\n  color: var(--white);\n}\n\n.linkDesc {\n  color: var(--New-Moon-10, #f0ece5);\n  font-family: var(--theme-font-family-body);\n  font-size: 10px;\n  font-style: normal;\n  font-weight: 500;\n  line-height: 14px; /* 140% */\n}\n\n/* CTA Items */\nli.grandchild.isCTA {\n  grid-column: 1 / -1;\n}\n\n.isCTA--title {\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: 12px;\n  letter-spacing: 0.14px;\n  margin-top: 10px;\n  margin-bottom: 0;\n  display: block;\n}\n\n/* Dropdown Caret */\n.dropdown-caret {\n  fill: var(--white);\n  transition: transform 0.28s ease-out 0.12s;\n}\n\n.nav-item-ctaLinkText {\n  display: block;\n  color: var(--gold-40) !important;\n}\n\n.grandchild--hasDescription:not(.isCTA) {\n  padding: 10px 20px;\n  transition: all 0.3s ease;\n}\n\n.grandchild--hasDescription:not(.isCTA):hover,\n.grandchild--hasDescription:not(.isCTA):focus {\n  border-radius: 5px;\n  background: var(--new-moon-80, #343247);\n}\n\n.dropdownTitle:hover .dropdown-caret,\n.dropdownTitle:focus .dropdown-caret {\n  fill: var(--white);\n}\n\n.dropdown.isOpen .dropdownTitle .dropdown-caret {\n  fill: var(--purple-40);\n  transform: rotate(-180deg);\n}\n\n/* Header Buttons */\n.headerNav .acds-button {\n  font-size: 14px;\n  line-height: 2.14;\n  padding: 8px 20px 9px 20px;\n}\n\n.header .login-link {\n  font-size: 14px;\n  font-weight: 500;\n  line-height: 1.78;\n  padding: 2px 14px;\n  color: inherit;\n}\n\n.header .buttons {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n}\n\n.grandchild {\n  padding: 8px;\n}\n\n/* ============================================\n   Desktop Hover States\n   ============================================ */\n@media screen and (min-width: 901px) {\n  .dropdownTitle:hover,\n  .dropdownTitle:focus {\n    background: var(--new-moon-80);\n  }\n\n  .dropdown:hover .dropdownMenu {\n    opacity: 1;\n    visibility: visible;\n  }\n\n  .dropdownTitle:hover .dropdown-caret,\n  .dropdownTitle:focus .dropdown-caret {\n    fill: var(--white);\n    transform: rotate(-180deg);\n  }\n\n  /* Light Theme Overrides */\n  html.light .header .dropdownTitle {\n    color: var(--new-moon-90);\n  }\n\n  html.light .header .dropdownTitle:hover {\n    background: var(--new-moon-10);\n  }\n\n  html.light .header .dropdownTitle .dropdown-caret {\n    fill: var(--new-moon-90);\n  }\n\n  html.light .header .dropdownTitle:hover .dropdown-caret,\n  html.light .header .dropdownTitle:focus .dropdown-caret {\n    fill: var(--new-moon-90);\n  }\n\n  html.light .header .search-button svg path {\n    fill: var(--new-moon-90);\n  }\n\n  html.light .header .login-link {\n    color: var(--new-moon-90);\n  }\n\n  .dropdownMenu.is-two-column {\n    display: grid;\n    grid-template-columns: 250px 260px;\n    gap: 36px;\n    align-items: center;\n  }\n}\n\n@media screen and (max-width: 940px) {\n  div.headerWrapper {\n    padding: 16px;\n  }\n  .headerNavList {\n    gap: 5px;\n  }\n}\n\n/* ============================================\n   Mobile Styles\n   ============================================ */\n@media screen and (max-width: 900px) {\n  .headerWrapper {\n    justify-content: space-between;\n  }\n\n  .headerNav {\n    display: none;\n    overflow-y: scroll;\n    flex-direction: column;\n    justify-content: flex-start;\n    gap: 2rem;\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    width: 100vw;\n    height: 100vh;\n    background: var(--new-moon-90);\n    z-index: 2;\n    padding-top: 7.75rem;\n  }\n\n  .headerNavList {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 0;\n    width: 100%;\n  }\n\n  /* Mobile Dropdown */\n  .dropdown {\n    width: 100%;\n    background: var(--new-moon-90);\n    border-bottom: 1px solid var(--grey-70);\n  }\n\n  .dropdown .dropdownTitle {\n    justify-content: space-between;\n    width: 100%;\n    font-size: 19px;\n    font-weight: 600;\n    color: var(--white);\n    background: transparent;\n  }\n\n  .dropdown .dropdownTitle.isActive {\n    color: var(--white);\n  }\n\n  .dropdown-caret {\n    width: 24px;\n    height: 24px;\n  }\n\n  /* Mobile Dropdown Menu */\n  .dropdown .dropdownMenu {\n    position: relative;\n    padding: 0;\n    margin: 0;\n    height: 0;\n    width: 100%;\n    border-radius: 0;\n    background: var(--new-moon-90);\n    flex-direction: column;\n    min-width: 100%;\n    border: none;\n    transition:\n      height 0.1s ease-out,\n      opacity 0.3s ease-out;\n  }\n\n  .dropdown.isOpen {\n    background: var(--new-moon-90);\n  }\n\n  .dropdown.isOpen .dropdownTitle + .dropdownMenu {\n    opacity: 1;\n    visibility: visible;\n    height: 100%;\n    width: 100%;\n    padding: 0;\n    display: flex;\n    padding-bottom: 20px;\n  }\n\n  .dropdown .dropdownMenu a,\n  .linkTitle.moreLink {\n    font-size: 16px;\n    line-height: 1;\n  }\n\n  /* Mobile Category Titles */\n  .dropdown .child.hasChildren .topTitle {\n    font-size: 12px;\n  }\n\n  /* Mobile Padding */\n  .grandchild,\n  .dropdownTitle,\n  .topTitle {\n    padding: 15px 1rem 17px 22px;\n    margin: 0;\n  }\n\n  .topTitle {\n    padding-bottom: 0;\n  }\n\n  .grandchild {\n    border-bottom: 1px solid var(--grey-60);\n  }\n\n  .grandchildren {\n    gap: 0;\n  }\n\n  /* Hide Mobile Elements */\n  .linkDesc {\n    display: none;\n  }\n\n  .linkTitle.moreLink + svg {\n    display: none;\n  }\n}\n "])</script><script>self.__next_f.push([1,"89:[[\"$\",\"style\",\"__fern-global-styles\",{\"children\":\"$91\"}]]\n8a:[\"$\",\"$L92\",null,{\"featureFlagsConfig\":{\"launchDarkly\":\"$undefined\"},\"children\":[\"$\",\"$L93\",null,{\"ErrorBoundary\":\"$94\",\"children\":[\"$\",\"div\",null,{\"data-body-theme\":\"default\",\"data-product-switcher-theme\":\"default\",\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L4\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]}]}]\n8b:[\"$\",\"$30\",null,{\"fallback\":null,\"children\":[\"$\",\"$L95\",null,{\"domain\":\"www.astronomer.io\",\"disableAnalytics\":false,\"lang\":\"en\"}]}]\n8d:[\"$\",\"$L96\",null,{\"config\":{\"ga4\":\"$undefined\",\"gtm\":{\"containerId\":\"GTM-WCJNSWTS\"}}}]\n"])</script><script>self.__next_f.push([1,"97:I[300203,[\"https://app.buildwithfern.com/_next/static/chunks/ad9c3e9bd4794e30.js\",\"https://app.buildwithfern.com/_next/static/chunks/48acc560e66d1721.js\",\"https://app.buildwithfern.com/_next/static/chunks/6efec50bb786e73a.js\",\"https://app.buildwithfern.com/_next/static/chunks/ae61028bdfe9c515.js\",\"https://app.buildwithfern.com/_next/static/chunks/c8c6cf8020a91179.js\",\"https://app.buildwithfern.com/_next/static/chunks/671fd44d7434620b.js\",\"https://app.buildwithfern.com/_next/static/chunks/402dc3e4afa1e4bb.js\",\"https://app.buildwithfern.com/_next/static/chunks/56ea871b88e42f77.js\",\"https://app.buildwithfern.com/_next/static/chunks/20a97d08ce1275d4.js\",\"https://app.buildwithfern.com/_next/static/chunks/3dedf9b4790bce6a.js\",\"https://app.buildwithfern.com/_next/static/chunks/1e001d49230832f1.js\",\"https://app.buildwithfern.com/_next/static/